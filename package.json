{
  "name": "freevoice-aac",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/assemble-dist.mjs",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "generate-icons": "node scripts/generate-icons.mjs",
    "generate-og": "node scripts/generate-og-image.mjs",
    "create-placeholders": "node scripts/create-character-placeholders.mjs",
    "slice-sprites": "node scripts/slice-sprites.mjs",
    "generate-assets": "npm run generate-icons && npm run generate-og",
    "license-audit": "npx license-checker --onlyAllow 'MIT;Apache-2.0;BSD-2-Clause;BSD-3-Clause;ISC;CC-BY-4.0;CC0-1.0;Unlicense'",
    "admin": "node admin/server.mjs",
    "admin:install": "cd admin && npm install",
    "cap:sync": "npx cap sync && node scripts/clear-android-assets.mjs",
    "cap:open": "npx cap open android",
    "build:apk:debug": "npm run build && npm run cap:sync && cd android && ./gradlew assembleDebug && cd .. && echo '✓ Debug APK built: android/app/build/outputs/apk/debug/app-debug.apk'",
    "build:apk:release": "npm run build && npm run cap:sync && cd android && ./gradlew assembleRelease && cd .. && echo '✓ Release APK built: android/app/build/outputs/apk/release/app-release.apk'",
    "build:bundle:release": "npm run build && npm run cap:sync && cd android && ./gradlew bundleRelease && cd .. && echo '✓ App Bundle built: android/app/build/outputs/bundle/release/app-release.aab'",
    "apk:generate-keystore": "bash scripts/generate-keystore.sh"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "dexie": "^4.3.0",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "kokoro-js": "^1.2.1",
    "pako": "^2.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.0",
    "react-router-dom": "^7.13.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^4.5.2",
    "@vitejs/plugin-react": "^4.0.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
